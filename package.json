{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --config=jest.config.mjs --testPathIgnorePatterns='.*\\.e2e-spec\\.ts$'",
    "test:e2e": "DOTENV_CONFIG_PATH=.env.test.local npx jest --config=jest.config.mjs",
    "test:cov:unit": "jest --config=jest.config.mjs --coverage --testPathIgnorePatterns='.*\\.e2e-spec\\.ts$'",
    "test:cov:e2e": "jest --config=jest.config.mjs --coverage --testRegex='\\.e2e-spec\\.ts$'",
    "test:cov:all": "jest --config=jest.config.mjs --coverage",
    "test:unit:jwt": "jest --config=jest.config.mjs --testPathPattern=jwt.strategy.spec.ts",
    "test:unit:auth": "jest --config=jest.config.mjs --testPathPattern=auth.service.spec.ts",
    "test:unit:login": "jest --config=jest.config.mjs --testPathPattern=login-validator.service.spec.ts",
    "test:unit:placement": "jest --config=jest.config.mjs --testPathPattern=placement.service.spec.ts",
    "test:unit:property": "jest --config=jest.config.mjs --testPathPattern=property.service.spec.ts",
    "test:unit:investment": "jest --config=jest.config.mjs --testPathPattern=investment.service.spec.ts",
    "test:unit:roles-guard": "jest --config=jest.config.mjs --testPathPattern=roles.guard.spec.ts",
    "test:unit:roles-decorator": "jest --config=jest.config.mjs --testPathPattern=roles.decorator.spec.ts",
    "test:e2e:app": "jest --config=jest.config.mjs --testRegex=app\\.e2e-spec\\.ts$",
    "test:e2e:placements": "jest --config=jest.config.mjs --testRegex=placements\\.e2e-spec\\.ts$",
    "test:e2e:properties": "jest --config=jest.config.mjs --testRegex=properties\\.e2e-spec\\.ts$",
    "test:e2e:investment": "jest --config=jest.config.mjs --testPathPattern=investment\\.e2e-spec\\.ts$",
    "test:e2e:auth": "jest --config=jest.config.mjs --testPathPattern=auth\\.e2e-spec\\.ts$",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down -v",
    "seed:dev:docker": "env DOTENV_CONFIG_PATH=.env npx dotenv -r dotenv/config ts-node -r tsconfig-paths/register src/data-source/seed.ts",
    "seed:dev:local": "DOTENV_CONFIG_PATH=.env.test.local node -r dotenv/config ts-node -r tsconfig-paths/register src/data-source/seed.ts",
    "seed:run": "node dist/data-source/seed.js",
    "prisma:seed": "npm run seed:run",
    "db:push": "prisma db push",
    "studio": "prisma studio"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^6.16.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
